# GEMINI_API_KEY: Clé API requise pour les appels à Gemini AI.
# Cette variable est utilisée uniquement côté serveur par les Netlify Functions.
# Ne l'ajoutez jamais dans les variables Vite publiques (VITE_...).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Configuration (Publique, utilisée côté client)
VITE_FIREBASE_API_KEY="your_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"
VITE_FIREBASE_DATABASE_ID="your_database_id_if_any"

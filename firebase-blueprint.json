{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Profil utilisateur du créateur",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "niche": { "type": "string" },
        "platform": { "type": "string", "enum": ["tiktok", "facebook", "both"] },
        "onboarding_completed": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "platform", "onboarding_completed"]
    },
    "Generation": {
      "title": "Generation",
      "description": "Contenu généré par l'IA",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "tool": { "type": "string", "enum": ["hooks", "script", "ideas", "calendar"] },
        "niche": { "type": "string" },
        "platform": { "type": "string" },
        "input_data": { "type": "object" },
        "output_data": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "tool", "niche", "platform", "input_data", "output_data", "created_at"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Profils des utilisateurs"
    },
    "/generations/{generationId}": {
      "schema": "Generation",
      "description": "Historique des générations"
    }
  }
}
